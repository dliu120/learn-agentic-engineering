# Copy to .env (gitignored). All optional — the site builds and the daily pipeline runs without any of these.

# Enables LLM curation of the daily feed. Without it, the pipeline uses deterministic templated curation.
ANTHROPIC_API_KEY=

# Curation model (default: claude-sonnet-4-6)
LLM_MODEL=claude-sonnet-4-6

# Polite User-Agent for source fetches
USER_AGENT=allm-academy-bot/1.0 (+https://allm-academy.example/about)

# Deploy overrides. For GitHub Pages project sites:
#   SITE=https://<user>.github.io  BASE=/<repo>/
SITE=
BASE=
