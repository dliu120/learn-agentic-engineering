---
import { MODULE_BY_ID } from '@/content/modules';
import { moduleHref, withBase, hue } from '@/lib/paths';
import type { DailyLesson } from '@/content/schemas/daily';

interface Props {
  lesson: DailyLesson;
}
const { lesson: l } = Astro.props;
const m = MODULE_BY_ID[l.module];
const linkUrl = (u: string) => (u.startsWith('http') ? u : withBase(u));
const primary = l.sourceLinks[0];
---

<article class="card p-5">
  <div class="flex flex-wrap items-center gap-2">
    <a href={moduleHref(l.module)} class="inline-flex items-center gap-1 rounded-full border px-2 py-0.5 text-[11px] no-underline" style={`color:${hue(m.colorHue, 70, 62)};border-color:${hue(m.colorHue, 60, 45, 0.5)}`}>
      {m.num} · {m.name}
    </a>
    <span class="text-[11px] text-text-faint">{l.meta.difficulty} · {l.meta.readingTimeMin} min</span>
  </div>

  <h3 class="mt-2 text-lg font-semibold leading-snug">
    <a href={linkUrl(primary.url)} class="text-text no-underline hover:text-accent" rel="noopener" target={primary.url.startsWith('http') ? '_blank' : undefined}>
      {l.headline}
    </a>
  </h3>

  <ul class="mt-3 space-y-1.5">
    {l.summaryBullets.map((b) => (
      <li class="flex gap-2 text-sm text-text-muted">
        <span class="mt-1 text-text-faint" aria-hidden="true">·</span>
        {b}
      </li>
    ))}
  </ul>

  <p class="mt-3 rounded-lg bg-surface-2 p-3 text-sm text-text">
    <span class="font-semibold text-accent">Why it matters — </span>{l.whyItMatters}
  </p>

  {l.microQuiz && (
    <details class="mt-3 rounded-lg border border-border p-3">
      <summary class="cursor-pointer text-sm font-medium text-text">Quick check: {l.microQuiz.question}</summary>
      <ol class="mt-2 space-y-1 text-sm text-text-muted">
        {l.microQuiz.options.map((o, i) => (
          <li class={i === l.microQuiz!.correct ? 'font-medium text-signal-good' : ''}>
            {i === l.microQuiz!.correct ? '✓ ' : '· '}
            {o}
          </li>
        ))}
      </ol>
      <p class="mt-2 text-xs text-text-faint">{l.microQuiz.explanation}</p>
    </details>
  )}

  <div class="mt-3 flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-text-faint">
    {l.sourceLinks.map((s) => (
      <a href={linkUrl(s.url)} class="hover:text-text" rel="noopener" target={s.url.startsWith('http') ? '_blank' : undefined}>
        ↗ {s.source}
      </a>
    ))}
    {l.tags.slice(0, 4).map((t) => (
      <span class="rounded bg-surface-2 px-1.5 py-0.5 font-mono">#{t}</span>
    ))}
  </div>
</article>
