---
import type { ModuleMeta } from '@/content/modules';
import { moduleHref, hue } from '@/lib/paths';

interface Props {
  module: ModuleMeta;
  lessonCount?: number;
}
const { module: m, lessonCount = 0 } = Astro.props;
---

<a
  href={moduleHref(m.id)}
  class="card group relative block overflow-hidden p-5 no-underline transition-transform hover:-translate-y-0.5"
  data-module={m.id}
  style={`--mhue:${m.colorHue}`}
>
  <span class="absolute inset-y-0 left-0 w-1" style={`background:${hue(m.colorHue)}`}></span>
  <div class="flex items-center justify-between">
    <span class="font-mono text-xs font-semibold" style={`color:${hue(m.colorHue, 70, 60)}`}>{m.num}</span>
    <span class="text-xs text-text-faint" data-module-progress-label={m.id}>{lessonCount} lessons</span>
  </div>
  <h3 class="mt-2 text-lg font-semibold text-text">{m.name}</h3>
  <p class="mt-1 text-sm text-text-muted">{m.short}</p>

  <div class="mt-4 h-1.5 w-full overflow-hidden rounded-full bg-surface-2">
    <div
      class="h-full rounded-full transition-[width] duration-500"
      style={`width:0%;background:${hue(m.colorHue)}`}
      data-module-progress-bar={m.id}
    >
    </div>
  </div>
  <div class="mt-3 flex items-center gap-1 text-sm" style={`color:${hue(m.colorHue, 70, 62)}`}>
    <span class="opacity-0 transition-opacity group-hover:opacity-100">Open</span>
    <span aria-hidden="true">→</span>
  </div>
</a>
