---
interface Props {
  title: string;
  tag?: string;
}
const { title, tag } = Astro.props;
---

<section class="card my-6 p-5">
  <div class="flex items-center justify-between">
    <h3 class="text-lg font-semibold text-text">{title}</h3>
    {tag && <span class="font-mono text-[10px] uppercase tracking-wider text-text-faint">{tag}</span>}
  </div>
  <div class="prose-tight mt-2 space-y-3">
    <slot />
  </div>
</section>
