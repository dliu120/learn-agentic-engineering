---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Quiz from '@/components/islands/Quiz.tsx';
import AudioPlayer from '@/components/islands/AudioPlayer.tsx';
import { MODULE_BY_ID } from '@/content/modules';
import { withBase, lessonHref, moduleHref, hue } from '@/lib/paths';

export async function getStaticPaths() {
  const lessons = await getCollection('lessons');
  return lessons.map((entry) => ({
    params: { id: entry.data.moduleId, lesson: entry.data.lessonId },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const d = entry.data;
const m = MODULE_BY_ID[d.moduleId];
const { Content } = await entry.render();

// sibling ordering: topic lessons by order, gate last
const sibs = (await getCollection('lessons', (e) => e.data.moduleId === d.moduleId)).sort((a, b) => {
  if (a.data.isModuleGate !== b.data.isModuleGate) return a.data.isModuleGate ? 1 : -1;
  return a.data.order - b.data.order;
});
const idx = sibs.findIndex((s) => s.data.lessonId === d.lessonId);
const prev = idx > 0 ? sibs[idx - 1] : null;
const next = idx < sibs.length - 1 ? sibs[idx + 1] : null;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const audioSrc = `${base}/audio/core/${d.moduleId}-${d.lessonId}.mp3`;
const vttSrc = `${base}/audio/core/${d.moduleId}-${d.lessonId}.vtt`;
---

<BaseLayout title={`${d.title} — ${m.name}`}>
  <nav class="text-sm text-text-faint" aria-label="Breadcrumb">
    <a href={withBase('/modules')} class="no-underline hover:text-text">Modules</a>
    <span class="mx-1">/</span>
    <a href={moduleHref(m.id)} class="no-underline hover:text-text" style={`color:${hue(m.colorHue, 70, 62)}`}>{m.name}</a>
  </nav>

  <article class="mx-auto mt-4 max-w-prose">
    <header class="border-l-4 pl-4" style={`border-color:${hue(m.colorHue)}`}>
      {d.isModuleGate && <p class="font-mono text-xs font-semibold text-signal-warn">★ Module gate</p>}
      <h1 class="text-fluid-xl font-bold text-text">{d.title}</h1>
      {
        d.objectives.length > 0 && (
          <ul class="mt-3 space-y-1">
            {d.objectives.map((o) => (
              <li class="flex gap-2 text-sm text-text-muted">
                <span style={`color:${hue(m.colorHue)}`}>▹</span>
                {o}
              </li>
            ))}
          </ul>
        )
      }
    </header>

    {d.hasAudio && <AudioPlayer client:visible src={audioSrc} vtt={vttSrc} transcript={d.narration} title={`Narration — ${d.title}`} />}

    <div class="lesson-body mt-6">
      <Content />
    </div>

    {
      d.quiz.length > 0 && (
        <Quiz client:visible questions={d.quiz} moduleId={d.moduleId} lessonId={d.lessonId} isGate={d.isModuleGate} colorHue={m.colorHue} />
      )
    }

    {
      !d.isModuleGate && d.quiz.length === 0 && (
        <button
          id="mark-complete"
          class="mt-8 rounded-lg border border-border px-4 py-2 text-sm text-text hover:bg-surface-2"
          data-module={d.moduleId}
          data-lesson={d.lessonId}
        >
          Mark lesson complete
        </button>
      )
    }

    <nav class="mt-12 flex items-center justify-between border-t border-border pt-6 text-sm" aria-label="Lesson navigation">
      {
        prev ? (
          <a href={lessonHref(prev.data.moduleId, prev.data.lessonId)} class="no-underline text-text-muted hover:text-text">
            ← {prev.data.title}
          </a>
        ) : (
          <span />
        )
      }
      {
        next ? (
          <a href={lessonHref(next.data.moduleId, next.data.lessonId)} class="text-right no-underline text-text-muted hover:text-text">
            {next.data.title} →
          </a>
        ) : (
          <a href={withBase('/modules')} class="text-right no-underline" style={`color:${hue(m.colorHue, 70, 62)}`}>
            Back to all modules →
          </a>
        )
      }
    </nav>
  </article>
</BaseLayout>

<script>
  import { setLastVisited, markLessonComplete, isLessonDone } from '@/lib/progress';
  // record visit (derive module/lesson from the URL)
  const parts = location.pathname.replace(/\/$/, '').split('/');
  const lessonId = parts.pop()!;
  const mod = parts.pop()!;
  if (mod && lessonId) setLastVisited(mod, lessonId);

  const btn = document.getElementById('mark-complete') as HTMLButtonElement | null;
  if (btn) {
    const sync = () =>
      (btn.textContent = isLessonDone(btn.dataset.module!, btn.dataset.lesson!) ? '✓ Completed' : 'Mark lesson complete');
    sync();
    btn.addEventListener('click', () => {
      markLessonComplete(btn.dataset.module!, btn.dataset.lesson!);
      sync();
    });
  }
</script>

<style>
  .lesson-body :global(h2) {
    @apply mt-10 text-xl font-semibold text-text;
  }
  .lesson-body :global(h3) {
    @apply mt-8 text-lg font-semibold text-text;
  }
  .lesson-body :global(p) {
    @apply mt-4 text-fluid leading-relaxed text-text-muted;
  }
  .lesson-body :global(ul),
  .lesson-body :global(ol) {
    @apply mt-4 list-disc space-y-1 pl-6 text-text-muted;
  }
  .lesson-body :global(code) {
    @apply rounded bg-surface-2 px-1 py-0.5 text-sm text-accent;
  }
  .lesson-body :global(strong) {
    @apply text-text;
  }
  .lesson-body :global(a) {
    @apply text-accent;
  }
</style>
