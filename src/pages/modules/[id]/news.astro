---
import BaseLayout from '@/layouts/BaseLayout.astro';
import DailyLessonCard from '@/components/ui/DailyLessonCard.astro';
import { MODULES, type ModuleMeta } from '@/content/modules';
import { newsForModule, prettyDate } from '@/lib/daily';
import { moduleHref, withBase, hue } from '@/lib/paths';

export async function getStaticPaths() {
  return MODULES.map((m) => ({ params: { id: m.id }, props: { module: m } }));
}
const { module: m } = Astro.props as { module: ModuleMeta };
const news = await newsForModule(m.id);
---

<BaseLayout title={`${m.name} — Related News`}>
  <a href={moduleHref(m.id)} class="text-sm text-text-muted no-underline hover:text-text">← {m.name}</a>
  <h1 class="mt-3 text-fluid-xl font-bold text-text" style={`color:${hue(m.colorHue, 70, 65)}`}>Trend feed: {m.name}</h1>
  <p class="mt-2 text-text-muted">Daily items the curator mapped to this module.</p>

  {
    news.length === 0 ? (
      <p class="mt-6 rounded-lg border border-dashed border-border p-4 text-sm text-text-faint">
        No daily items tagged to this module yet. Check the <a href={withBase('/today')}>today's briefing</a>.
      </p>
    ) : (
      <div class="mt-6 space-y-4">
        {news.map(({ date, lesson }) => (
          <div>
            <p class="mb-1 text-xs text-text-faint">{prettyDate(date)}</p>
            <DailyLessonCard lesson={lesson} />
          </div>
        ))}
      </div>
    )
  }
</BaseLayout>
