---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Search — ALLM Academy">
  <h1 class="text-fluid-xl font-bold text-text">Search</h1>
  <p class="mt-1 text-text-muted">Full-text search across lessons, the glossary, and daily briefings.</p>
  <p class="mt-1 text-xs text-text-faint">Tip: press <kbd class="kbd">⌘K</kbd> anywhere to jump to a module or lesson.</p>

  <div id="search" class="mt-6"></div>
  <p id="search-fallback" hidden class="mt-4 text-sm text-text-faint">
    The search index is generated at build time (<code>npm run build</code>). It isn't available in the dev server —
    run a production build and preview to use it.
  </p>
</BaseLayout>

<script is:inline define:vars={{ base: import.meta.env.BASE_URL }}>
  const css = document.createElement('link');
  css.rel = 'stylesheet';
  css.href = base + 'pagefind/pagefind-ui.css';
  document.head.appendChild(css);

  const s = document.createElement('script');
  s.src = base + 'pagefind/pagefind-ui.js';
  s.onload = () => {
    // eslint-disable-next-line no-undef
    new PagefindUI({ element: '#search', showSubResults: true, showImages: false });
  };
  s.onerror = () => {
    const f = document.getElementById('search-fallback');
    if (f) f.hidden = false;
  };
  document.body.appendChild(s);
</script>
