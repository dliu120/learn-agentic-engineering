---
import '@/styles/global.css';
import { getCollection } from 'astro:content';
import Header from '@/components/ui/Header.astro';
import Footer from '@/components/ui/Footer.astro';
import CommandPalette from '@/components/islands/CommandPalette.tsx';
import { MODULES, MODULE_BY_ID } from '@/content/modules';
import { withBase, lessonHref, moduleHref } from '@/lib/paths';

interface Props {
  title?: string;
  description?: string;
  wide?: boolean;
}
const {
  title = 'ALLM Academy — Production-LLM Engineering',
  description = 'An immersive, self-updating course on harness, inference, RAG, evals, and safety for AI engineers.',
  wide = false,
} = Astro.props;

// Build-time nav index for the ⌘K palette.
const lessons = await getCollection('lessons');
const paletteItems = [
  { title: 'Dashboard', href: withBase('/'), kind: 'page' },
  { title: 'All modules', href: withBase('/modules'), kind: 'page' },
  { title: "Today's briefing", href: withBase('/today'), kind: 'page' },
  { title: 'Archive', href: withBase('/archive'), kind: 'page' },
  { title: 'Glossary', href: withBase('/glossary'), kind: 'page' },
  ...MODULES.map((m) => ({ title: m.name, href: moduleHref(m.id), kind: m.num })),
  ...lessons.map((l) => ({
    title: l.data.title,
    href: lessonHref(l.data.moduleId, l.data.lessonId),
    kind: MODULE_BY_ID[l.data.moduleId].num,
  })),
];
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={import.meta.env.BASE_URL + 'favicon.svg'} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
    />
    {/* Pre-hydration theme resolution to avoid flash-of-wrong-theme (§17.3). */}
    <script is:inline>
      (() => {
        try {
          const t = localStorage.getItem('allm:theme') ?? 'system';
          const dark = t === 'dark' || (t === 'system' && matchMedia('(prefers-color-scheme: dark)').matches);
          document.documentElement.dataset.theme = dark ? 'dark' : 'light';
        } catch (_) {}
      })();
    </script>
  </head>
  <body class="min-h-screen">
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main" class:list={['mx-auto px-4 py-8', wide ? 'max-w-7xl' : 'max-w-6xl']}>
      <slot />
    </main>
    <Footer />
    <CommandPalette client:idle items={paletteItems} />
  </body>
</html>
