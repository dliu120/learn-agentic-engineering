{
  "name": "allm-academy",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "An immersive, self-updating production-LLM engineering course (static Astro site).",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && pagefind --site dist",
    "build:fast": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "gen:audio": "tsx scripts/gen-audio.ts",
    "daily": "tsx scripts/daily/run.ts",
    "daily:dry": "tsx scripts/daily/run.ts --dry-run",
    "check:coverage": "tsx scripts/check-coverage.ts",
    "test": "vitest run",
    "lint": "astro check"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/preact": "^6.0.0",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^7.0.3",
    "gsap": "^3.15.0",
    "preact": "^10.29.3",
    "tailwindcss": "^4.3.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/node": "^26.0.1",
    "pagefind": "^1.5.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
