{
  "name": "allm-academy",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "An immersive, self-updating production-LLM engineering course (static Astro site).",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && pagefind --site dist",
    "build:fast": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "gen:audio": "tsx scripts/gen-audio.ts",
    "daily": "tsx scripts/daily/run.ts",
    "daily:dry": "tsx scripts/daily/run.ts --dry-run",
    "check:coverage": "tsx scripts/check-coverage.ts",
    "test": "vitest run",
    "lint": "astro check"
  },
  "dependencies": {
    "@astrojs/mdx": "^3.1.9",
    "@astrojs/preact": "^3.5.4",
    "@astrojs/tailwind": "^5.1.5",
    "astro": "^4.16.18",
    "gsap": "^3.12.5",
    "preact": "^10.25.4",
    "tailwindcss": "^3.4.17",
    "yaml": "^2.7.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/node": "^22.10.5",
    "pagefind": "^1.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
