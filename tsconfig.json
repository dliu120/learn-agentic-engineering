{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "types": ["node"],
    "verbatimModuleSyntax": false
  },
  "include": ["src", "scripts", "tests", ".astro/types.d.ts"],
  "exclude": ["dist", "node_modules"]
}
